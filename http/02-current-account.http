### Current Account Service
# BIAN-compliant current account operations: deposits, withdrawals, liens, valuation features.
# Proto: api/proto/meridian/current_account/v1/current_account.proto
# Gateway: HTTP/JSON via Vanguard transcoding

## --- Setup: Create Party + Account ---

### Register Party (for account setup)
POST {{host}}/v1/parties
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "partyType": "PARTY_TYPE_PERSON",
  "legalName": "Account Test User",
  "displayName": "Account Tester"
}

> {%
    client.global.set("ca_party_id", response.body.party.partyId);
%}

### Open Current Account (GBP)
POST {{host}}/v1/current-accounts
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "partyId": "{{ca_party_id}}",
  "accountIdentification": "GB82WEST12345698765432",
  "baseCurrency": "CURRENCY_GBP"
}

> {%
    client.global.set("ca_account_id", response.body.accountId);
%}

### Open Current Account (USD)
POST {{host}}/v1/current-accounts
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "partyId": "{{ca_party_id}}",
  "accountIdentification": "GB45WEST12345612345678",
  "baseCurrency": "CURRENCY_USD"
}

### Retrieve Account
GET {{host}}/v1/current-accounts/{{ca_account_id}}
X-Tenant-ID: {{tenant_id}}

### Update Account
PUT {{host}}/v1/current-accounts/{{ca_account_id}}
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "overdraftLimit": {
    "amount": {
      "currencyCode": "GBP",
      "units": "500"
    }
  }
}

## --- Deposits ---

### Deposit 1000 GBP
POST {{host}}/v1/current-accounts/{{ca_account_id}}/deposits
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "amount": {
    "amount": {
      "currencyCode": "GBP",
      "units": "1000"
    }
  },
  "description": "Salary credit",
  "reference": "SAL-2025-01",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

### Deposit fractional amount
POST {{host}}/v1/current-accounts/{{ca_account_id}}/deposits
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "amount": {
    "amount": {
      "currencyCode": "GBP",
      "units": "0",
      "nanos": 990000000
    }
  },
  "description": "Interest payment",
  "reference": "INT-001",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

## --- Withdrawals (two-phase) ---

### Initiate Withdrawal
POST {{host}}/v1/current-accounts/{{ca_account_id}}/withdrawals:initiate
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "amount": {
    "amount": {
      "currencyCode": "GBP",
      "units": "250"
    }
  },
  "description": "ATM withdrawal",
  "reference": "ATM-001",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

> {%
    client.global.set("ca_withdrawal_id", response.body.withdrawal.withdrawalId);
%}

### Execute Withdrawal (two-phase)
POST {{host}}/v1/current-accounts/{{ca_account_id}}/withdrawals:execute
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "withdrawalId": "{{ca_withdrawal_id}}",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

### Retrieve Withdrawal
GET {{host}}/v1/withdrawals/{{ca_withdrawal_id}}
X-Tenant-ID: {{tenant_id}}

## --- Withdrawals (direct execution) ---

### Direct Withdrawal (skip initiate)
POST {{host}}/v1/current-accounts/{{ca_account_id}}/withdrawals:execute
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "amount": {
    "amount": {
      "currencyCode": "GBP",
      "units": "50"
    }
  },
  "description": "POS purchase",
  "reference": "POS-001",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

## --- Liens ---

### Initiate Lien
POST {{host}}/v1/current-accounts/{{ca_account_id}}/liens
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "amount": {
    "amount": {
      "currencyCode": "GBP",
      "units": "200"
    }
  },
  "paymentOrderReference": "PO-TEST-001",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

> {%
    client.global.set("ca_lien_id", response.body.lien.lienId);
%}

### Retrieve Lien
GET {{host}}/v1/current-account-liens/{{ca_lien_id}}
X-Tenant-ID: {{tenant_id}}

### Execute Lien
POST {{host}}/v1/current-account-liens/{{ca_lien_id}}/execute
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

### Initiate Another Lien (for termination test)
POST {{host}}/v1/current-accounts/{{ca_account_id}}/liens
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "amount": {
    "amount": {
      "currencyCode": "GBP",
      "units": "100"
    }
  },
  "paymentOrderReference": "PO-TEST-002",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

> {%
    client.global.set("ca_lien_id_2", response.body.lien.lienId);
%}

### Terminate Lien
POST {{host}}/v1/current-account-liens/{{ca_lien_id_2}}/terminate
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "reason": "Payment order cancelled"
}

### Get Active Amount Blocks
GET {{host}}/v1/current-accounts/{{ca_account_id}}/amount-blocks
X-Tenant-ID: {{tenant_id}}

## --- Account Lifecycle ---

### Control Account (freeze)
POST {{host}}/v1/current-accounts/{{ca_account_id}}/control
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "action": "CONTROL_ACTION_FREEZE",
  "reason": "Suspicious activity investigation"
}

### Control Account (unfreeze)
POST {{host}}/v1/current-accounts/{{ca_account_id}}/control
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "action": "CONTROL_ACTION_UNFREEZE",
  "reason": "Investigation cleared"
}

## --- Valuation Features ---

### Create Valuation Feature (EUR->GBP)
POST {{host}}/v1/current-accounts/{{ca_account_id}}/valuation-features
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "instrumentCode": "EUR",
  "valuationMethodId": "fx-spot-rate",
  "valuationMethodVersion": 1,
  "outputInstrument": "GBP",
  "parameters": "{\"spread\": \"0.002\"}"
}

> {%
    client.global.set("ca_vf_id", response.body.feature.id);
%}

### List Valuation Features
GET {{host}}/v1/current-accounts/{{ca_account_id}}/valuation-features
X-Tenant-ID: {{tenant_id}}

### Get Valuation Feature
GET {{host}}/v1/current-account-valuation-features/{{ca_vf_id}}
X-Tenant-ID: {{tenant_id}}

### Evaluate Asset Valuation (inquiry)
POST {{host}}/v1/current-accounts/{{ca_account_id}}/valuations:evaluate
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "input": {
    "amount": "500.00",
    "instrumentCode": "EUR"
  }
}
