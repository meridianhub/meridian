### Market Information Service
# Market data management: datasets, sources, observations for valuation and pricing.
# Proto: api/proto/meridian/market_information/v1/market_information.proto
# Gateway: HTTP/JSON via Vanguard transcoding
# Note: Datasets and sources use a 'code' identifier (e.g., "FX_USD_GBP"), not an ID.

## --- Datasets ---

### Register Dataset
POST {{host}}/v1/market-information/datasets
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "code": "FX_USD_GBP",
  "category": "DATA_CATEGORY_FX",
  "unit": "RATE",
  "resolutionKeyExpression": "instrument_code",
  "displayName": "USD/GBP FX Spot Rate",
  "description": "Live USD/GBP spot rates from Reuters",
  "effectiveFrom": "2026-01-01T00:00:00Z",
  "idempotencyKey": {
    "key": "{{$uuid}}"
  }
}

> {%
    client.global.set("mi_dataset_code", response.body.dataset.code);
%}

### Retrieve Dataset
GET {{host}}/v1/market-information/datasets/{{mi_dataset_code}}
X-Tenant-ID: {{tenant_id}}

### Update Dataset
PATCH {{host}}/v1/market-information/datasets/{{mi_dataset_code}}
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "description": "Live USD/GBP spot rates from Reuters (updated feed)"
}

### Activate Dataset
POST {{host}}/v1/market-information/datasets/{{mi_dataset_code}}/activate
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "version": 1
}

### List Datasets
GET {{host}}/v1/market-information/datasets
X-Tenant-ID: {{tenant_id}}

### Deprecate Dataset
POST {{host}}/v1/market-information/datasets/{{mi_dataset_code}}/deprecate
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "version": 1
}

## --- Data Sources ---

### Register Data Source
POST {{host}}/v1/market-information/sources
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "code": "REUTERS_FX",
  "name": "reuters-fx",
  "description": "Reuters FX feed"
}

> {%
    client.global.set("mi_source_code", response.body.source.code);
%}

### Update Data Source
PATCH {{host}}/v1/market-information/sources/{{mi_source_code}}
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "description": "Reuters FX feed (primary)"
}

### List Data Sources
GET {{host}}/v1/market-information/sources
X-Tenant-ID: {{tenant_id}}

### Deactivate Data Source
POST {{host}}/v1/market-information/sources/{{mi_source_code}}/deactivate
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{}

## --- Observations ---

### Record Single Observation
POST {{host}}/v1/market-information/observations
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "datasetCode": "{{mi_dataset_code}}",
  "sourceCode": "{{mi_source_code}}",
  "instrumentCode": "EUR/GBP",
  "value": "0.8456"
}

> {%
    client.global.set("mi_obs_id", response.body.observation.observationId);
%}

### Record Batch Observations
POST {{host}}/v1/market-information/observations/batch
Content-Type: application/json
X-Tenant-ID: {{tenant_id}}

{
  "observations": [
    {
      "datasetCode": "{{mi_dataset_code}}",
      "sourceCode": "{{mi_source_code}}",
      "instrumentCode": "USD/GBP",
      "value": "0.7923"
    },
    {
      "datasetCode": "{{mi_dataset_code}}",
      "sourceCode": "{{mi_source_code}}",
      "instrumentCode": "JPY/GBP",
      "value": "0.005234"
    }
  ]
}

### Retrieve Observation
GET {{host}}/v1/market-information/observations/{{mi_obs_id}}
X-Tenant-ID: {{tenant_id}}

### List Observations
GET {{host}}/v1/market-information/datasets/{{mi_dataset_code}}/observations?pageSize=50
X-Tenant-ID: {{tenant_id}}
