# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log

# Dependency directories
node_modules/

# Environment variables
.env

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS specific
.DS_Store

# Task Master (managed at parent directory level)
# Ignore runtime state but track the templates directory so contributors
# can find the canonical PRD template.
.taskmaster/*
!.taskmaster/templates/
!.taskmaster/templates/**
CLAUDE.md
.mcp.json

# Go specific
vendor/
dist/
*.test
coverage.out
*.exe
*.dll
*.so
*.dylib
*.out
__debug_bin

# Service binaries (built from services/*/)
/audit-worker
/current-account
/financial-accounting
/party
/payment-order
/position-keeping
/tenant

# Generated protobuf files (regenerate with buf or make proto)
# Excluded globally but committed under api/proto/ for readability
*.pb.go
*.pb.validate.go
*_grpc.pb.go
!api/proto/**/*.pb.go
!api/proto/**/*.pb.validate.go
!api/proto/**/*_grpc.pb.go

# Generated OpenAPI specs (regenerate with buf generate)
api/openapi/*
!api/openapi/swagger-ui.html
__pycache__/
# Add current-account binary to .gitignore (use leading / to avoid matching directories)
/current-account

# Local development secrets (generated from .example files)
deployments/k8s/*/secret.yaml
deployments/k8s/base/secret.yaml
*.local.md

# IntelliJ HTTP Client private environment (may contain secrets)
http/http-client.private.env.json

# Demo deployment secrets
deploy/demo/.env.demo
deploy/demo/certs/*.pem

# Compiled binary
/meridian
