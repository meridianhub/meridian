{
  "version": "1.0",
  "metadata": {
    "name": "PAYG Energy Billing",
    "industry": "energy",
    "description": "Prepayment energy billing with no-standing-charge block tariff, emergency credit, debt recovery waterfall, and DCC smart meter integration. Two-tier pricing (First Rate / Saver Rate with daily 2kWh threshold), VAT recognition at top-up (HMRC Reg 86), and MHHS-ready half-hourly consumption settlement."
  },
  "instruments": [
    {
      "code": "GBP",
      "name": "British Pound Sterling",
      "type": "INSTRUMENT_TYPE_FIAT",
      "dimensions": {
        "unit": "GBP",
        "precision": 2
      }
    },
    {
      "code": "KWH_ELEC",
      "name": "Kilowatt Hour (Electricity)",
      "type": "INSTRUMENT_TYPE_COMMODITY",
      "dimensions": {
        "unit": "kWh",
        "precision": 3
      }
    },
    {
      "code": "KWH_GAS",
      "name": "Kilowatt Hour (Gas)",
      "type": "INSTRUMENT_TYPE_COMMODITY",
      "dimensions": {
        "unit": "kWh",
        "precision": 3
      }
    }
  ],
  "accountTypes": [
    {
      "code": "PREPAYMENT_LIABILITY",
      "name": "Customer Prepayment Liability",
      "normalBalance": "NORMAL_BALANCE_CREDIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "",
        "bucketing": "attributes.fuel_type"
      }
    },
    {
      "code": "EMERGENCY_CREDIT",
      "name": "Emergency Credit Receivable",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "amount >= 0 && amount <= 15",
        "bucketing": "attributes.fuel_type"
      }
    },
    {
      "code": "POWER_UP_RECEIVABLE",
      "name": "POWER UP (ASC) Receivable",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "",
        "bucketing": ""
      }
    },
    {
      "code": "DEBT_RECOVERY",
      "name": "Debt Recovery Receivable",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "amount > 0",
        "bucketing": ""
      }
    },
    {
      "code": "REVENUE_ENERGY",
      "name": "Energy Revenue",
      "normalBalance": "NORMAL_BALANCE_CREDIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "",
        "bucketing": "attributes.fuel_type + ':' + attributes.rate_tier + ':' + attributes.settlement_period"
      }
    },
    {
      "code": "VAT_OUTPUT",
      "name": "VAT Output Tax",
      "normalBalance": "NORMAL_BALANCE_CREDIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "",
        "bucketing": "attributes.tax_period"
      }
    },
    {
      "code": "CONSUMPTION_METERED",
      "name": "Metered Consumption",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "KWH_ELEC",
        "KWH_GAS"
      ],
      "policies": {
        "validation": "amount > 0",
        "bucketing": "instrument_code + ':' + attributes.settlement_period + ':' + attributes.mpxn"
      }
    },
    {
      "code": "ENERGY_SUPPLY_POOL",
      "name": "Energy Supply Pool",
      "normalBalance": "NORMAL_BALANCE_CREDIT",
      "allowedInstruments": [
        "KWH_ELEC",
        "KWH_GAS"
      ],
      "policies": {
        "validation": "",
        "bucketing": "instrument_code + ':' + attributes.settlement_period + ':' + attributes.gsp_group"
      }
    },
    {
      "code": "WHOLESALE_COST",
      "name": "Wholesale Energy Cost",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "",
        "bucketing": "attributes.fuel_type + ':' + attributes.settlement_period"
      }
    },
    {
      "code": "WHD_OBLIGATION",
      "name": "Warm Home Discount Obligation",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "",
        "bucketing": "attributes.scheme_year"
      }
    }
  ],
  "valuationRules": [
    {
      "fromInstrument": "KWH_ELEC",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_FIXED",
      "source": "PAYG_ELEC_FIRST_RATE"
    },
    {
      "fromInstrument": "KWH_ELEC",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_FIXED",
      "source": "PAYG_ELEC_SAVER_RATE"
    },
    {
      "fromInstrument": "KWH_GAS",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_FIXED",
      "source": "PAYG_GAS_FIRST_RATE"
    },
    {
      "fromInstrument": "KWH_GAS",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_FIXED",
      "source": "PAYG_GAS_SAVER_RATE"
    },
    {
      "fromInstrument": "KWH_ELEC",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_SPOT_RATE",
      "source": "WHOLESALE_ELEC_GBP_KWH"
    },
    {
      "fromInstrument": "KWH_GAS",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_SPOT_RATE",
      "source": "WHOLESALE_GAS_GBP_KWH"
    }
  ],
  "sagas": [
    {
      "name": "topup_waterfall",
      "trigger": "scheduled:payg_topup",
      "script": "output = {\"status\": \"STUB\"}"
    },
    {
      "name": "consumption_block_tariff",
      "trigger": "event:position-keeping.transaction-captured.v1",
      "filter": "(event.instrument_code == 'KWH_ELEC' || event.instrument_code == 'KWH_GAS') && event.direction == 'DEBIT'",
      "script": "output = {\"status\": \"STUB\"}"
    },
    {
      "name": "emergency_credit_activate",
      "trigger": "scheduled:payg_emergency_credit",
      "script": "output = {\"status\": \"STUB\"}"
    },
    {
      "name": "whd_credit_apply",
      "trigger": "scheduled:payg_whd_credit",
      "script": "output = {\"status\": \"STUB\"}"
    }
  ],
  "seedData": {
