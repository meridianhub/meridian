{
  "version": "1.0",
  "metadata": {
    "name": "Wasters Waste Tracking Demo",
    "industry": "waste-management",
    "description": "Digital waste tracking platform billing demo: hybrid base-plus-usage economy metering completed waste movements and tonnage, with monthly included allowances, hazardous-movement overage premium, and weighbridge estimate-to-actual reconciliation"
  },
  "instruments": [
    {
      "code": "GBP",
      "name": "British Pound Sterling",
      "type": "INSTRUMENT_TYPE_FIAT",
      "dimensions": {
        "unit": "GBP",
        "precision": 2
      }
    },
    {
      "code": "WASTE_MOVEMENT",
      "name": "Waste Movement",
      "type": "INSTRUMENT_TYPE_COMMODITY",
      "dimensions": {
        "unit": "movements",
        "precision": 0
      }
    },
    {
      "code": "TONNE_WASTE",
      "name": "Tonne of Waste",
      "type": "INSTRUMENT_TYPE_COMMODITY",
      "dimensions": {
        "unit": "tonnes",
        "precision": 3
      }
    }
  ],
  "accountTypes": [
    {
      "code": "MOVEMENT_METERED",
      "name": "Metered Waste Movements",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "WASTE_MOVEMENT"
      ],
      "policies": {
        "validation": "amount > 0",
        "bucketing": "attributes.billing_period + ':' + attributes.hazard_class"
      }
    },
    {
      "code": "TONNAGE_METERED",
      "name": "Metered Waste Tonnage",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "TONNE_WASTE"
      ],
      "policies": {
        "validation": "amount > 0",
        "bucketing": "attributes.billing_period + ':' + attributes.ewc_chapter"
      }
    },
    {
      "code": "MOVEMENT_ALLOWANCE",
      "name": "Included Movement Allowance",
      "normalBalance": "NORMAL_BALANCE_CREDIT",
      "allowedInstruments": [
        "WASTE_MOVEMENT"
      ],
      "policies": {
        "validation": "amount > 0",
        "bucketing": ""
      }
    },
    {
      "code": "TONNAGE_ALLOWANCE",
      "name": "Included Tonnage Allowance",
      "normalBalance": "NORMAL_BALANCE_CREDIT",
      "allowedInstruments": [
        "TONNE_WASTE"
      ],
      "policies": {
        "validation": "amount > 0",
        "bucketing": ""
      }
    },
    {
      "code": "WASTE_BILLING",
      "name": "Customer Waste Billing Receivable",
      "normalBalance": "NORMAL_BALANCE_DEBIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "amount > 0",
        "bucketing": "attributes.billing_period"
      }
    },
    {
      "code": "REVENUE_WASTE",
      "name": "Waste Services Revenue",
      "normalBalance": "NORMAL_BALANCE_CREDIT",
      "allowedInstruments": [
        "GBP"
      ],
      "policies": {
        "validation": "",
        "bucketing": "attributes.charge_type + ':' + attributes.billing_period"
      }
    }
  ],
  "valuationRules": [
    {
      "fromInstrument": "WASTE_MOVEMENT",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_FIXED",
      "source": "WASTE_MOVEMENT_STD_RATE"
    },
    {
      "fromInstrument": "WASTE_MOVEMENT",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_FIXED",
      "source": "WASTE_MOVEMENT_HAZ_RATE"
    },
    {
      "fromInstrument": "TONNE_WASTE",
      "toInstrument": "GBP",
      "method": "VALUATION_METHOD_FIXED",
      "source": "WASTE_TONNE_RATE"
    }
  ],
  "sagas": [
    {
      "name": "record_waste_movement",
      "trigger": "webhook:waste_movement_completed",
      "script": "output = {\"status\": \"STUB\"}"
    },
    {
      "name": "meter_billing",
      "trigger": "event:position-keeping.transaction-captured.v1",
      "filter": "(event.instrument_code == 'WASTE_MOVEMENT' || event.instrument_code == 'TONNE_WASTE') && event.direction == 'DEBIT'",
      "script": "output = {\"status\": \"STUB\"}"
    },
    {
      "name": "weighbridge_true_up",
      "trigger": "webhook:weighbridge_actual",
      "script": "output = {\"status\": \"STUB\"}"
    },
    {
      "name": "generate_waste_invoice",
      "trigger": "scheduled:monthly_waste_billing",
      "script": "output = {\"status\": \"STUB\"}"
    }
  ],
  "seedData": {},
  "paymentRails": [],
  "partyTypes": [],
  "mappings": [],
  "marketData": {
    "sources": [
      {
        "code": "SEED_DEMO",
        "name": "Seed Demo Data Source",
        "description": "Synthetic tariff data generated by seed-dev for demonstration purposes",
        "trustLevel": 80
      }
    ],
    "datasets": [
      {
        "code": "WASTE_MOVEMENT_STD_RATE",
        "category": "DATA_CATEGORY_COMMODITY_PRICE",
        "unit": "GBP/movement",
        "sourceCode": "SEED_DEMO",
        "displayName": "Standard Movement Overage Rate",
        "description": "GBP charged per non-hazardous waste movement beyond the monthly included allowance",
        "validationExpression": "true",
        "resolutionKeyExpression": "observed_at"
      },
      {
        "code": "WASTE_MOVEMENT_HAZ_RATE",
        "category": "DATA_CATEGORY_COMMODITY_PRICE",
        "unit": "GBP/movement",
        "sourceCode": "SEED_DEMO",
        "displayName": "Hazardous Movement Overage Rate",
        "description": "GBP charged per hazardous waste movement (consignment note workflow) beyond the monthly included allowance",
        "validationExpression": "true",
        "resolutionKeyExpression": "observed_at"
      },
      {
        "code": "WASTE_TONNE_RATE",
        "category": "DATA_CATEGORY_COMMODITY_PRICE",
        "unit": "GBP/tonne",
        "sourceCode": "SEED_DEMO",
        "displayName": "Tonnage Overage Rate",
        "description": "GBP charged per tonne moved beyond the monthly included allowance, rate-flat regardless of waste classification",
        "validationExpression": "true",
        "resolutionKeyExpression": "observed_at"
      },
      {
        "code": "WASTE_BASE_FEE",
        "category": "DATA_CATEGORY_COMMODITY_PRICE",
        "unit": "GBP/month",
        "sourceCode": "SEED_DEMO",
        "displayName": "Monthly Base Platform Fee",
        "description": "Subscription floor charged each billing period before usage",
        "validationExpression": "true",
        "resolutionKeyExpression": "observed_at"
      },
      {
        "code": "WASTE_INCLUDED_MOVEMENTS",
        "category": "DATA_CATEGORY_COMMODITY_PRICE",
        "unit": "movements/month",
        "sourceCode": "SEED_DEMO",
        "displayName": "Included Movements Per Month",
        "description": "Movement allowance granted at each period open, classification-blind",
        "validationExpression": "true",
        "resolutionKeyExpression": "observed_at"
      },
      {
        "code": "WASTE_INCLUDED_TONNES",
        "category": "DATA_CATEGORY_COMMODITY_PRICE",
        "unit": "tonnes/month",
        "sourceCode": "SEED_DEMO",
        "displayName": "Included Tonnes Per Month",
        "description": "Tonnage allowance granted at each period open",
        "validationExpression": "true",
        "resolutionKeyExpression": "observed_at"
      }
    ]
  },
  "organizations": [
    {
      "code": "SKIPCO",
      "name": "SkipCo Containers Ltd",
      "partyType": "ORGANIZATION",
      "externalReference": "CBDU100001",
      "externalReferenceType": "NATIONAL_ID",
      "attributes": {
        "role": "carrier",
        "archetype": "skip-hire SME: ~40 mixed construction-waste collections per month, no hazardous",
        "external_reference": "CBDU100001"
      }
    },
    {
      "code": "HAZCHEM",
      "name": "HazChem Logistics Ltd",
      "partyType": "ORGANIZATION",
      "externalReference": "CBDU100002",
      "externalReferenceType": "NATIONAL_ID",
      "attributes": {
        "role": "carrier",
        "archetype": "hazardous waste carrier: ~120 movements per month, majority consignment-note workflow",
        "external_reference": "CBDU100002"
      }
    },
    {
      "code": "BROKERX",
      "name": "BrokerX Waste Solutions Ltd",
      "partyType": "ORGANIZATION",
      "externalReference": "CBDU100003",
      "externalReferenceType": "NATIONAL_ID",
      "attributes": {
        "role": "broker",
        "archetype": "multi-site broker: high movement count at low tonnage, candidate for pooled commitments",
        "external_reference": "CBDU100003"
      }
    }
  ],
  "internalAccounts": [
    {
      "code": "MOVEMENT_METERED_SKIPCO",
      "accountType": "MOVEMENT_METERED",
      "instrument": "WASTE_MOVEMENT",
      "ownerOrganization": "SKIPCO",
      "description": "Completed movement meter for SkipCo - one unit per completed waste transfer note"
    },
    {
      "code": "TONNAGE_METERED_SKIPCO",
      "accountType": "TONNAGE_METERED",
      "instrument": "TONNE_WASTE",
      "ownerOrganization": "SKIPCO",
      "description": "Tonnage meter for SkipCo - declared at completion, trued up at weighbridge"
    },
    {
      "code": "MOVEMENT_ALLOWANCE_SKIPCO",
      "accountType": "MOVEMENT_ALLOWANCE",
      "instrument": "WASTE_MOVEMENT",
      "ownerOrganization": "SKIPCO",
      "description": "Monthly included movement allowance for SkipCo, granted at period open and drained by metering"
    },
    {
      "code": "TONNAGE_ALLOWANCE_SKIPCO",
      "accountType": "TONNAGE_ALLOWANCE",
      "instrument": "TONNE_WASTE",
      "ownerOrganization": "SKIPCO",
      "description": "Monthly included tonnage allowance for SkipCo"
    },
    {
      "code": "WASTE_BILLING_SKIPCO",
      "accountType": "WASTE_BILLING",
      "instrument": "GBP",
      "ownerOrganization": "SKIPCO",
      "description": "GBP billing receivable for SkipCo - base fee plus metered overage"
    },
    {
      "code": "MOVEMENT_METERED_HAZCHEM",
      "accountType": "MOVEMENT_METERED",
      "instrument": "WASTE_MOVEMENT",
      "ownerOrganization": "HAZCHEM",
      "description": "Completed movement meter for HazChem - hazardous movements bucket separately via hazard_class"
    },
    {
      "code": "TONNAGE_METERED_HAZCHEM",
      "accountType": "TONNAGE_METERED",
      "instrument": "TONNE_WASTE",
      "ownerOrganization": "HAZCHEM",
      "description": "Tonnage meter for HazChem"
    },
    {
      "code": "MOVEMENT_ALLOWANCE_HAZCHEM",
      "accountType": "MOVEMENT_ALLOWANCE",
      "instrument": "WASTE_MOVEMENT",
      "ownerOrganization": "HAZCHEM",
      "description": "Monthly included movement allowance for HazChem - classification-blind, premium applies to overage only"
    },
    {
      "code": "TONNAGE_ALLOWANCE_HAZCHEM",
      "accountType": "TONNAGE_ALLOWANCE",
      "instrument": "TONNE_WASTE",
      "ownerOrganization": "HAZCHEM",
      "description": "Monthly included tonnage allowance for HazChem"
    },
    {
      "code": "WASTE_BILLING_HAZCHEM",
      "accountType": "WASTE_BILLING",
      "instrument": "GBP",
      "ownerOrganization": "HAZCHEM",
      "description": "GBP billing receivable for HazChem"
    }
  ],
  "operationalGateway": {
    "providerConnections": [
      {
        "connectionId": "waste_movement_completed",
        "providerName": "Wasters Compliance Platform (movement events)",
        "providerType": "waste_tracking",
        "protocol": "PROVIDER_PROTOCOL_WEBHOOK",
        "baseUrl": "https://api.wasters.example/webhooks",
        "auth": {
          "hmac": {
            "algorithm": "sha256",
            "secretRef": "sm://wasters/movement_webhook_secret",
            "signatureHeader": "X-Signature"
          }
        }
      },
      {
        "connectionId": "weighbridge_actual",
        "providerName": "Wasters Compliance Platform (weighbridge tickets)",
        "providerType": "waste_tracking",
        "protocol": "PROVIDER_PROTOCOL_WEBHOOK",
        "baseUrl": "https://api.wasters.example/webhooks",
        "auth": {
          "hmac": {
            "algorithm": "sha256",
            "secretRef": "sm://wasters/weighbridge_webhook_secret",
            "signatureHeader": "X-Signature"
          }
        }
      }
    ],
    "instructionRoutes": [],
    "inboundRoutes": []
  }
}
