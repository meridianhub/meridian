#!/bin/bash
# Pre-commit hook for Meridian
# Runs code quality checks before allowing commit

set -e

echo "🔍 Running pre-commit checks..."

# Check if golangci-lint is installed
if ! command -v golangci-lint &> /dev/null; then
    echo "❌ golangci-lint is not installed"
    echo "   Install it with: make install"
    echo "   Or: curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b \$(go env GOPATH)/bin"
    exit 1
fi

# Get staged Go files (excluding generated protobuf files)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | grep -v '\.pb\.go$' | grep -v '\.pb\.validate\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    echo "✅ No Go files to check"
    exit 0
fi

echo "📝 Checking ${STAGED_GO_FILES}"

# Run gofmt check
echo "  - Running gofmt..."
UNFORMATTED=$(gofmt -l ${STAGED_GO_FILES} || true)
if [ -n "$UNFORMATTED" ]; then
    echo "❌ Go files not formatted. Run:"
    echo "   make fmt"
    echo ""
    echo "   Files:"
    echo "$UNFORMATTED" | sed 's/^/     /'
    exit 1
fi

# Run golangci-lint on staged files
echo "  - Running golangci-lint..."
golangci-lint run --new-from-rev=HEAD ${STAGED_GO_FILES}

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Linting failed. Fix the issues or run:"
    echo "   make lint"
    exit 1
fi

echo "✅ Pre-commit checks passed!"
exit 0
