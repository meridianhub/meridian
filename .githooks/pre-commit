#!/bin/bash
# Pre-commit hook for Meridian
# Runs validation on staged files:
# - gofumpt and golangci-lint on Go files
# - buf lint and buf breaking on proto files

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Ensure GOPATH/bin is in PATH for tools
export PATH="$PATH:$(go env GOPATH)/bin"

# Get list of staged files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
STAGED_PROTO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.proto$' || true)
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -z "$STAGED_GO_FILES" ] && [ -z "$STAGED_PROTO_FILES" ] && [ -z "$STAGED_MD_FILES" ]; then
    echo -e "${GREEN}✓${NC} No Go, proto, or markdown files to check"
    exit 0
fi

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# ============================================================================
# PROTO FILE CHECKS
# ============================================================================

if [ -n "$STAGED_PROTO_FILES" ]; then
    # Check if buf is installed (pinned version for consistency)
    BUF_VERSION="v1.47.2"
    if ! command -v buf &> /dev/null; then
        echo -e "${YELLOW}⚠${NC}  buf not found, installing $BUF_VERSION..."
        go install github.com/bufbuild/buf/cmd/buf@$BUF_VERSION
    fi

    # Run buf lint
    echo -e "${YELLOW}→${NC} Running buf lint on proto files..."
    if buf lint; then
        echo -e "${GREEN}✓${NC} buf lint passed"
    else
        echo -e "${RED}✗${NC} buf lint failed"
        echo -e "${RED}Please fix proto style issues above before committing${NC}"
        echo -e "${YELLOW}Tip:${NC} See docs/skills/schema-evolution.md for proto guidelines"
        exit 1
    fi

    # Run buf breaking (check against develop branch)
    echo -e "${YELLOW}→${NC} Checking for breaking proto changes..."
    # Only run if develop branch exists locally
    if git rev-parse --verify develop >/dev/null 2>&1; then
        if buf breaking --against '.git#branch=develop'; then
            echo -e "${GREEN}✓${NC} No breaking proto changes"
        else
            echo -e "${RED}✗${NC} Breaking proto changes detected"
            echo -e "${RED}Please review proto compatibility issues above${NC}"
            echo -e "${YELLOW}Tip:${NC} See docs/skills/schema-evolution.md for safe evolution patterns"
            echo -e "${YELLOW}Tip:${NC} Consider adding optional fields or creating new event types"
            exit 1
        fi
    else
        echo -e "${YELLOW}⚠${NC}  Skipping buf breaking check (develop branch not found locally)"
        echo -e "${YELLOW}   Run: git fetch origin develop:develop${NC}"
    fi
fi

# ============================================================================
# MARKDOWN FILE CHECKS
# ============================================================================

if [ -n "$STAGED_MD_FILES" ]; then
    # Convert newline-separated list to array, filtering empty lines (done once)
    MD_FILES_ARRAY=()
    while IFS= read -r file; do
        [[ -n "$file" ]] && MD_FILES_ARRAY+=("$file")
    done <<< "$STAGED_MD_FILES"

    # Check if npm is available and package.json exists
    if [ -f "package.json" ] && command -v npm &> /dev/null; then
        # Run markdownlint-cli2 via npm on staged markdown files
        echo -e "${YELLOW}→${NC} Running markdownlint on markdown files..."

        if npm run --silent lint:md -- "${MD_FILES_ARRAY[@]}"; then
            echo -e "${GREEN}✓${NC} markdownlint passed"
        else
            echo -e "${RED}✗${NC} markdownlint failed"
            echo -e "${RED}Please fix markdown style issues above before committing${NC}"
            echo -e "${YELLOW}Tip:${NC} Run 'npm run lint:md:fix' to auto-fix some issues"
            exit 1
        fi
    elif command -v npx &> /dev/null; then
        # Fallback to npx if package.json not present
        # Note: Run 'npm install' once for optimal performance (avoids package download on each commit)
        echo -e "${YELLOW}→${NC} Running markdownlint on markdown files..."

        if npx --yes markdownlint-cli2 "${MD_FILES_ARRAY[@]}"; then
            echo -e "${GREEN}✓${NC} markdownlint passed"
        else
            echo -e "${RED}✗${NC} markdownlint failed"
            echo -e "${RED}Please fix markdown style issues above before committing${NC}"
            echo -e "${YELLOW}Tip:${NC} Run 'npx markdownlint-cli2 --fix <filename>' to auto-fix issues"
            exit 1
        fi
    else
        echo -e "${YELLOW}⚠${NC}  npx not found, skipping markdown linting"
        echo -e "${YELLOW}   Install Node.js and npm to enable markdown linting${NC}"
    fi
fi

# ============================================================================
# GO FILE CHECKS
# ============================================================================

if [ -z "$STAGED_GO_FILES" ]; then
    echo -e "${GREEN}✓${NC} No Go files to check"
    echo -e "${GREEN}✓${NC} All pre-commit checks passed"
    exit 0
fi

# Check if gofumpt is installed
if ! command -v gofumpt &> /dev/null; then
    echo -e "${YELLOW}⚠${NC}  gofumpt not found, installing..."
    go install mvdan.cc/gofumpt@latest
fi

# Check if golangci-lint is installed
if ! command -v golangci-lint &> /dev/null; then
    echo -e "${YELLOW}⚠${NC}  golangci-lint not found, installing..."
    curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b "$(go env GOPATH)/bin" v2.5.0
fi

# Format staged Go files with gofumpt
echo -e "${YELLOW}→${NC} Running gofumpt..."
for file in $STAGED_GO_FILES; do
    gofumpt -w "$file"
    git add "$file"
done
echo -e "${GREEN}✓${NC} gofumpt passed"

# Run golangci-lint per directory
echo -e "${YELLOW}→${NC} Running golangci-lint..."
LINT_FAILED=0

# Group files by directory and run golangci-lint per directory
for dir in $(echo "$STAGED_GO_FILES" | xargs -n1 dirname | sort -u); do
    if ! golangci-lint run --config=.golangci.yml "$dir"; then
        LINT_FAILED=1
    fi
done

if [ $LINT_FAILED -eq 0 ]; then
    echo -e "${GREEN}✓${NC} golangci-lint passed"
else
    echo -e "${RED}✗${NC} golangci-lint failed"
    echo -e "${RED}Please fix the issues above before committing${NC}"
    exit 1
fi

echo -e "${GREEN}✓${NC} All pre-commit checks passed"
