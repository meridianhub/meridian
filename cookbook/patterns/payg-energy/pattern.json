{
    "$schema": "https://cookbook.meridianhub.org/schema/registry-item.json",
    "name": "payg-energy",
    "type": "registry:pattern",
    "title": "Prepayment Energy Billing (PAYG)",
    "description": "Complete prepayment energy billing model with no-standing-charge block tariff, emergency credit, debt recovery waterfall, DCC smart meter integration, and MHHS-ready half-hourly settlement. Models Utilita-style two-tier pricing with VAT at top-up (HMRC Reg 86).",
    "registryDependencies": ["base-fiat-gbp"],
    "categories": ["energy", "utilities", "prepayment", "billing"],
    "meta": {
        "complexity": 5,
        "trigger": "mixed",
        "design_pattern": "allocation-waterfall",
        "industries": ["energy", "utilities"],
        "provides": {
            "instruments": ["KWH_ELEC", "KWH_GAS"],
            "account_types": [
                "PREPAYMENT_LIABILITY",
                "EMERGENCY_CREDIT",
                "POWER_UP_RECEIVABLE",
                "DEBT_RECOVERY",
                "REVENUE_ENERGY",
                "VAT_OUTPUT",
                "CONSUMPTION_METERED",
                "ENERGY_SUPPLY_POOL",
                "WHOLESALE_COST",
                "WHD_OBLIGATION"
            ],
            "sagas": [
                "topup_waterfall",
                "consumption_block_tariff",
                "emergency_credit_activate",
                "whd_credit_apply"
            ],
            "valuation_rules": [
                "elec_first_rate",
                "elec_saver_rate",
                "gas_first_rate",
                "gas_saver_rate",
                "wholesale_elec",
                "wholesale_gas"
            ],
            "triggers": [
                "api:/v1/topups",
                "api:/v1/emergency-credit/activate",
                "api:/v1/whd/apply",
                "event:position-keeping.transaction-captured.v1"
            ]
        },
        "requires": {
            "instruments": ["GBP"],
            "market_data": [
                "UTILITA_ELEC_FIRST_RATE",
                "UTILITA_ELEC_SAVER_RATE",
                "UTILITA_GAS_FIRST_RATE",
                "UTILITA_GAS_SAVER_RATE",
                "WHOLESALE_ELEC_GBP_KWH",
                "WHOLESALE_GAS_GBP_KWH"
            ]
        },
        "composes_with": ["payment-gateway-stripe", "kyc-compliance"],
        "conflicts_with": ["time-of-use-pricing"],
        "extends": ["energy-settlement"]
    },
    "files": [
        {
            "path": "patterns/payg-energy/manifest-fragment.yaml",
            "type": "registry:file",
            "target": "~/manifest-fragment.yaml"
        },
        {
            "path": "patterns/payg-energy/topup_waterfall.star",
            "type": "registry:file",
            "target": "~/sagas/topup_waterfall.star"
        },
        {
            "path": "patterns/payg-energy/consumption_block_tariff.star",
            "type": "registry:file",
            "target": "~/sagas/consumption_block_tariff.star"
        },
        {
            "path": "patterns/payg-energy/emergency_credit_activate.star",
            "type": "registry:file",
            "target": "~/sagas/emergency_credit_activate.star"
        },
        {
            "path": "patterns/payg-energy/whd_credit_apply.star",
            "type": "registry:file",
            "target": "~/sagas/whd_credit_apply.star"
        }
    ]
}
