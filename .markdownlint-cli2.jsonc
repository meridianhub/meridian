// markdownlint-cli2 configuration
// See https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
{
  "config": {
    // Default state for all rules
    "default": true,

    // MD013/line-length - Line length
    // Relaxed to 120 characters (default is 80)
    "MD013": {
      "line_length": 120,
      "heading_line_length": 120,
      "code_block_line_length": 120,
      "code_blocks": true,
      "tables": false,
      "headings": true,
      "strict": false,
      "stern": false
    },

    // MD024/no-duplicate-heading - Multiple headings with the same content
    // Allow duplicate headings in different sections
    "MD024": {
      "siblings_only": true
    },

    // MD033/no-inline-html - Inline HTML
    // Allow inline HTML (common in READMEs for badges, tables, etc.)
    "MD033": false,

    // MD041/first-line-heading - First line in a file should be a top-level heading
    // Disabled as some files have front matter or comments first
    "MD041": false,

    // MD051/link-fragments - Link fragments should be valid
    // Disabled as it has false positives with valid TOC links
    "MD051": false,

    // MD060/table-column-style - Table column formatting
    // Disabled as table formatting styles vary and are cosmetic only
    "MD060": false
  },

  // Fix mode - automatically fix issues where possible
  "fix": true,

  // Globs are specified in package.json scripts or command line
  // to allow flexible usage (pre-commit hooks vs full linting)
  "ignores": [
    "**/node_modules/**",
    "**/.git/**",
    // Canonical AI-contributor instruction doc, maintained as the project
    // source of truth. Excluded so it stays faithful to upstream rather than
    // being reflowed for line-length/code-fence rules.
    "CLAUDE.md",
    ".taskmaster/**",
    ".claude/**",
    ".assess/**",
    "docs/architecture/**",
    "docs/adr/**",
    "docs/analysis/**",
    "docs/spec/**"
  ]
}
