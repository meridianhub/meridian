# SECURITY NOTE: This is an EXAMPLE template for local development.
#
# DO NOT commit actual credentials to git!
#
# Setup instructions:
# 1. Copy this file to secret.yaml: cp secret.yaml.example secret.yaml
# 2. Replace <REPLACE_WITH_*> placeholders with actual values
# 3. For local development, use: postgres://<user>@cockroachdb:26257/<database>?sslmode=disable
#
# For production deployments:
# - Use External Secrets Operator or Sealed Secrets
# - See docs/secrets-management.md for production setup
# - NEVER commit real credentials to version control
apiVersion: v1
kind: Secret
metadata:
  name: meridian-db
  labels:
    app: meridian
type: Opaque
stringData:
  # Example: postgres://myuser:mypassword@cockroachdb:26257/mydatabase?sslmode=disable
  DATABASE_URL: "<REPLACE_WITH_DATABASE_URL>"
