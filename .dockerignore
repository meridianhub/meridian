# Meridian .dockerignore
# Excludes unnecessary files from Docker build context

# Git
.git
.gitignore
.gitattributes
.githooks

# Documentation
README.md
LICENSE
docs/
*.md

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Build artifacts
dist/
build/
bin/
*.exe
*.test
*.out

# Test coverage
coverage/
coverage.out
*.coverprofile

# Go module cache (already in container)
vendor/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# Kubernetes manifests (will be in separate deployment)
k8s/
manifests/
deployments/

# Environment files
.env
.env.*
*.env

# Task Master
.taskmaster/

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db
